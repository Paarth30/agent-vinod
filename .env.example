# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# Gemini API (get from aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# Contact finding (at least one recommended)
HUNTER_API_KEY=your_hunter_key_here
APOLLO_API_KEY=your_apollo_key_here

# Email sending (Gmail recommended)
EMAIL_ADDRESS=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here   # Use an App Password, not your real password

# LinkedIn credentials (for Easy Apply automation)
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password_here

# Job search preferences
JOB_TITLES=Software Engineer,Backend Developer,Python Developer
JOB_LOCATION=Remote
JOB_KEYWORDS=Python,FastAPI,Django
MAX_JOBS_PER_RUN=20
MIN_ATS_SCORE=50
